        <DiffEqn symbol-ref="H">
            <Expression>1*(alpha*2*A^2/(1+A^2)-deltah*H)</Expression>
        </DiffEqn>
    </Disabled>
-->
                <DiffEqn symbol-ref="H">
                    <Expression>1*(alpha*A-deltah*H)</Expression>
                </DiffEqn>
            </System>
            <System time-scaling="0.040" time-step="0.05" name="PIP3" solver="Euler [fixed, O(1)]">
                <!--    <Disabled>
        <Intermediate symbol="G" value="1*((5*U+1)*P2*0.00072 - 0.432*P3)"/>
    </Disabled>
-->
                <Intermediate symbol="G" value="((P2) * (0.41 + 0.26 * 3.7*s+0.26) - (1.59) * P3)"/>
                <DiffEqn symbol-ref="P3">
                    <Expression>G</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="P2">
                    <Expression>-G</Expression>
                </DiffEqn>
                <Rule symbol-ref="rate">
                    <Expression>G</Expression>
                </Rule>
