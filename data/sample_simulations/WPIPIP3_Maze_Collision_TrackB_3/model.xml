            </MembraneProperty>
            <MembraneProperty symbol="B" name="Inactive form of protein" value="7.31-rand_uni(-0.1,0.1)-0.5">
                <Diffusion rate="1*1/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="H" name="Local Rac inhibtor" value="2">
                <Diffusion rate="0.09/lengthscale^2"/>
