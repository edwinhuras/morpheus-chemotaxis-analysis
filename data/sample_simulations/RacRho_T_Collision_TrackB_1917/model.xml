            <PropertyVector symbol="p" name="polarity" value="0.0, 0.0, 0.0"/>
            <Mapper name="Polarity extraction from membrane">
                <Input value="R"/>
                <Polarity symbol-ref="p"/>
            </Mapper>
            <StarConvex membrane="R - Rho" strength="10"/>
            <Protrusion maximum="500" strength="10" field="prot"/>
            <MembraneProperty symbol="s" name="signal" value="0">
                <Diffusion rate="0"/>
            </MembraneProperty>
            <Mapper name="Sensing the field">
                <Input value="U"/>
                <Output symbol-ref="s" mapping="average"/>
            </Mapper>
            <Constant symbol="targ_Perimeter" value="174.0"/>
            <Property symbol="Area" value="0.0"/>
            <Property symbol="Perimeter" value="0.0"/>
            <Property symbol="perimeter_diff" value="0.0"/>
            <Constant symbol="T_0" value="3.0"/>
            <Property symbol="Tension" value="0.0"/>
            <System time-step="0.05" solver="Dormand-Prince [adaptive, O(5)]">
                <Rule symbol-ref="Area">
                    <Expression>cell.volume</Expression>
                </Rule>
                <Rule symbol-ref="Perimeter">
                    <Expression>cell.surface</Expression>
                </Rule>
                <Rule symbol-ref="Tension">
                    <Expression>if(Perimeter - targ_Perimeter > 0, Perimeter - targ_Perimeter, 0)</Expression>
                </Rule>
                <!--    <Disabled>
        <Rule symbol-ref="Tension">
            <Expression>perimeter_diff^n_T / ( K_T ^ n_T +  perimeter_diff ^ n_T )</Expression>
        </Rule>
    </Disabled>
-->
            </System>
        </CellType>
    </CellTypes>
    <CPM>
        <Interaction default="0.0"/>
        <MonteCarloSampler stepper="edgelist">
            <MCSDuration value="0.3"/>
            <Neighborhood>
                <Order>2</Order>
            </Neighborhood>
            <MetropolisKinetics yield="0.05" temperature="1"/>
        </MonteCarloSampler>
        <ShapeSurface scaling="norm">
            <Neighborhood>
                <Order>6</Order>
            </Neighborhood>
        </ShapeSurface>
    </CPM>
    <CellPopulations>
        <Population type="cells" size="0" name="TrackB">
            <InitCellObjects mode="distance">
                <Arrangement displacements="1, 1, 0" repetitions="1, 1, 0">
                    <Sphere radius="21" center="lattice.x*0.25, 0.05*lattice.y, 0"/>
                </Arrangement>
            </InitCellObjects>
        </Population>
