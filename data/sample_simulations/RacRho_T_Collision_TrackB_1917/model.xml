    <CellTypes>
        <CellType class="biological" name="cells">
            <VolumeConstraint target="1385" strength="1"/>
            <SurfaceConstraint target="1.2" strength="0.8" mode="aspherity"/>
            <MembraneProperty symbol="R" name="Active form of protein" value="0.5+rand_uni(-0.1,0.1)">
                <Diffusion rate="0.12/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="R_i" name="Inactive form of protein" value="7.31-rand_uni(-0.1,0.1)-0.5">
                <Diffusion rate="1*1/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="Rho" name="Active form of protein" value="0.5+rand_uni(-0.1,0.1)">
                <Diffusion rate="0.12/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="Rho_i" name="Inactive form of protein" value="7.31-rand_uni(-0.1,0.1)-0.5">
                <Diffusion rate="1*1/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="H" name="Local Rac inhibtor" value="2">
                <Diffusion rate="0.09/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="P2" value="3.08-0.93">
                <Diffusion rate="DP/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="P3" value="0.93">
                <Diffusion rate="DP/lengthscale^2"/>
            </MembraneProperty>
            <System time-step="0.05" name="WavePinning Rac" time-scaling="5" solver="Euler [fixed, O(1)]">
                <Constant symbol="k_0" value="rand_norm(0.028, 0.000765)"/>
                <Constant symbol="k_1" value="rand_norm(0.372, 0.006632)"/>
                <Constant symbol="s_1" value="rand_norm(0.059, 0.001530)"/>
                <Constant symbol="gamma" value="rand_norm(1.38, 0.0214)"/>
                <Constant symbol="delta" value="rand_norm(0.721, 0.006887)"/>
                <Constant symbol="K" value="rand_norm(2.93, 0.0408)"/>
                <Constant symbol="n" name="Hill coefficient" value="2"/>
                <Intermediate symbol="F" value="1*(R_i*(k_0+ s_1*(0.93+0.5*s) + (gamma) / (1 + Rho^n) ) - (delta+k_1*H)*R)"/>
                <DiffEqn symbol-ref="R">
                    <Expression>F</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="R_i">
                    <Expression>-F</Expression>
                </DiffEqn>
            </System>
            <System time-step="0.05" name="WavePinning Rho" time-scaling="5" solver="Euler [fixed, O(1)]">
                <Constant symbol="k_0_rho" value="rand_norm(0.028, 0.000765)"/>
                <Constant symbol="k_1_rho" value="rand_norm(0.372, 0.006632)"/>
                <Constant symbol="s_1_rho" value="rand_norm(0.059, 0.001530)"/>
                <Constant symbol="gamma_rho" value="rand_norm(1.38, 0.0214)"/>
                <Constant symbol="delta_rho" value="rand_norm(0.721, 0.006887)"/>
                <Constant symbol="K_rho" value="rand_norm(2.93, 0.0408)"/>
                <Constant symbol="K_T" name="Tension Hill function parameter" value="5.0"/>
                <Constant symbol="n_T" name="Tension Hill coefficient" value="4"/>
                <Constant symbol="n" name="Hill coefficient" value="2"/>
                <Intermediate symbol="G" value="1*(Rho_i*(k_0_rho+ s_1_rho*(0.93) + (gamma_rho) / (1 + R^n) + T_0 * Tension^n_T / ( K_T ^ n_T + Tension ^ n_T ) ) - (delta_rho+k_1_rho*H)*Rho)"/>
                <DiffEqn symbol-ref="Rho">
                    <Expression>G</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="Rho_i">
                    <Expression>-G</Expression>
                </DiffEqn>
            </System>
