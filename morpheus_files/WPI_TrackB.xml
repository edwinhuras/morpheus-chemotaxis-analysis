<MorpheusModel version="4">
    <Description>
    <Title>Wave-Pinning with Inhibitor (WPI) Model</Title>
    <Details>Model ID:	[To be assigned]
  File type:	Supplementary model
  Software:	Morpheus (open source). Download from: https://morpheus.gitlab.io
Full title:	Mechanochemical Feedback Enables Efficient Navigation in Complex Chemical Gradients
Authors:	E. Huras, J. Algorta, H. De Belly, O. D. Weiner, L. Edelstein-Keshet
Submitter:	Edwin Huras
Curator:	[Your Name]
Date:	[Current Date]
Reference:	This model is an extension of the Wave-Pinning model, introduced and implemented in:
	J. Algorta, J. P. Town, O. D. Weiner, L. Edelstein-Keshet: Investigating local negative feedback of Rac activity by mathematical models and cell-motility simulations. iScience 29 (2): 114641, 2026.
	https://doi.org/10.1016/j.isci.2026.114641
	The original Wave-Pinning concept was introduced in:
	Y. Mori, A. Jilkine, L. Edelstein-Keshet: Wave-Pinning and Cell Polarity from a Bistable Reaction-Diffusion System. Biophysical Journal 94 (9): 3684–3697, 2008. https://doi.org/10.1529/biophysj.107.120824
Comment:	This model extends the basic wave-pinning (WP) system by adding a local negative feedback loop mediated by a downstream inhibitor of Rac.</Details>
</Description>
    <Global>
        <Constant symbol="lengthscale" value="(1)*2*pi/132"/>
        <Constant symbol="ts1" name="Time to *end* first light stimulus from &quot;time = 0&quot;" value="0"/>
        <Constant symbol="ts2" name="Time to *starts* second light stimulus from &quot;time = ts2&quot;" value="10"/>
                <Constant symbol="L" name="Angular size of the light stimulus" value="pi/3"/>
        <Variable symbol="A" value="0.0"/>
        <Variable symbol="B" value="0.0"/>
                <Field symbol="prot" value="0.0"/>
                                                                <Variable symbol="ts3" value="1000000"/>
        <Field symbol="U" value="0.0">
                                    <TIFFReader filename="TrackB_300x450_grayscale_16bit.tiff" scaling="1.0"/>
        </Field>
                        <Constant symbol="noise" value="0"/>
        <Function symbol="noisy">
            <Parameter symbol="v" name="value"/>
            <Expression>max(0,(v+rand_norm(0,noise)))</Expression>
        </Function>
        <Constant symbol="iteration_dummy" value="1"/>
        <Constant symbol="middle" value="3*pi/2+rand_uni(-0.3,0.3)"/>
        <Constant symbol="DH" value="0.04"/>
        <Constant symbol="DP" value="0.62"/>
    </Global>
    <Space>
                <SpaceSymbol symbol="l"/>
        <MembraneLattice>
            <Resolution symbol="memsize" value="500"/>
            <SpaceSymbol symbol="m"/>
        </MembraneLattice>
                                        <Lattice name="TrackB" class="square">
            <Size symbol="lattice" value="300, 450, 0"/>
            <BoundaryConditions>
                <Condition type="noflux" boundary="x"/>
                <Condition type="noflux" boundary="y"/>
            </BoundaryConditions>
            <NodeLength value="1.0"/>
            <Neighborhood>
                <Distance>2.0</Distance>
            </Neighborhood>
            <Domain boundary-type="constant">
                                <Image path="TrackB_300x450.tiff"/>
            </Domain>
        </Lattice>
            </Space>
    <Time>
        <StartTime value="0"/>
        <StopTime value="4000"/>
        <SaveInterval value="0"/>
        <!--    <Disabled>
        <RandomSeed value="0"/>
    </Disabled>
-->
        <TimeSymbol symbol="time"/>
    </Time>
    <CellTypes>
                                <CellType name="cells" class="biological">
            <VolumeConstraint target="1385" strength="1"/>
            <SurfaceConstraint target="1.2" strength="0.8" mode="aspherity"/>
            <MembraneProperty symbol="A" name="Active form of protein" value="0.5+rand_uni(-0.1,0.1)">
                <Diffusion rate="0.12/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="B" name="Inactive form of protein" value="7.31-rand_uni(-0.1,0.1)-0.5">
                <Diffusion rate="1*1/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="H" name="Local Rac inhibtor" value="2">
                <Diffusion rate="0.09/lengthscale^2"/>
            </MembraneProperty>
                        <MembraneProperty symbol="P3" value="0.93">
                <Diffusion rate="DP/lengthscale^2"/>
            </MembraneProperty>
            <MembraneProperty symbol="P2" value="3.08-0.93">
                <Diffusion rate="DP/lengthscale^2"/>
            </MembraneProperty>
            <System time-scaling="5" time-step="0.05" name="WavePinning with Inhibitor" solver="Euler [fixed, O(1)]">
                <Constant symbol="k_0" value="rand_norm(0.028, 0.000765)"/>
                <Constant symbol="k_1" value="rand_norm(0.372, 0.006632)"/>
                <Constant symbol="s_1" value="rand_norm(0.059, 0.001530)"/>
                                                <Constant symbol="gamma" value="rand_norm(1.38, 0.0214)"/>
                <Constant symbol="delta" value="rand_norm(0.721, 0.006887)"/>
                <Constant symbol="K" value="rand_norm(2.93, 0.0408)"/>
                <Constant symbol="n" name="Hill coefficient" value="2"/>
                                <Intermediate symbol="F" value="1*(B*(k_0+ s_1*(0.93+0.5*s) + (gamma*A^n) / (K^n + A^n) ) - (delta+k_1*H+0.000*T)*A)"/>
                <DiffEqn symbol-ref="A">
                    <Expression>F</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="B">
                    <Expression>-F</Expression>
                </DiffEqn>
                <Rule symbol-ref="rate1">
                    <Expression>F</Expression>
                </Rule>
            </System>
            <System time-scaling="5" time-step="0.05" name="Inhibitor" solver="Euler [fixed, O(1)]">
                <Constant symbol="alpha" value="rand_norm(0.0068, 0.000102040)"/>
                <Constant symbol="deltah" value="rand_norm(0.004, 0.00015306)"/>
                                <DiffEqn symbol-ref="H">
                    <Expression>1*(alpha*A-deltah*H)</Expression>
                </DiffEqn>
            </System>
                                    <PropertyVector symbol="p" name="polarity" value="0.0, 0.0, 0.0"/>
            <Mapper name="Polarity extraction from membrane">
                <Input value="A"/>
                <Polarity symbol-ref="p"/>
            </Mapper>
            <StarConvex membrane="A" strength="10"/>
            <Protrusion strength="10" field="prot" maximum="500"/>
                        <Property symbol="T" name="Tension" value="0"/>
                                                                                                                                    <Event>
                <Condition>(abs(p.phi-pi/2)&lt;0.25)*(time>ts2+10)</Condition>
                <Rule symbol-ref="ts3">
                    <Expression>time+0</Expression>
                </Rule>
            </Event>
            <MembraneProperty symbol="rate" value="0.0">
                <Diffusion rate="0.0"/>
            </MembraneProperty>
            <MembraneProperty symbol="rate1" value="0.0">
                <Diffusion rate="0.0"/>
            </MembraneProperty>
            <Mapper name="Polarity extraction from membrane">
                <Input value="U"/>
                <Polarity symbol-ref="p1"/>
            </Mapper>
            <PropertyVector symbol="p1" name="polarity1" value="0.0, 0.0, 0.0"/>
            <System solver="Dormand-Prince [adaptive, O(5)]">
                <Rule symbol-ref="T">
                    <Expression>160-cell.surface</Expression>
                </Rule>
            </System>
                                                <MembraneProperty symbol="s" name="signal" value="0">
                <Diffusion rate="0"/>
            </MembraneProperty>
            <Mapper name="Sensing the field">
                <Input value="U"/>
                <Output symbol-ref="s" mapping="average"/>
            </Mapper>
        </CellType>
            </CellTypes>
    <CPM>
        <Interaction default="0.0"/>
        <MonteCarloSampler stepper="edgelist">
            <MCSDuration value="0.3"/>
            <Neighborhood>
                <Order>2</Order>
            </Neighborhood>
            <MetropolisKinetics yield="0.05" temperature="1"/>
        </MonteCarloSampler>
        <ShapeSurface scaling="norm">
            <Neighborhood>
                <Order>6</Order>
            </Neighborhood>
        </ShapeSurface>
    </CPM>
    <CellPopulations>
                                                        <Population type="cells" name="TrackB" size="0">
            <InitCellObjects mode="distance">
                <Arrangement repetitions="1, 1, 0" displacements="1, 1, 0">
                    <Sphere center="lattice.x*0.25, 0.05*lattice.y, 0" radius="21"/>
                </Arrangement>
            </InitCellObjects>
        </Population>
            </CellPopulations>
        <Analysis>
        <Gnuplotter time-step="10" decorate="false">
            <Terminal name="png"/>
            <Plot title="Active Protein &amp; Light Stimulus">
                <Cells value="A"/>
                <CellArrows orientation="p*70"/>
                <Field symbol-ref="U" max="1" min="0">
                    <ColorMap>
                        <Color value="0.01" color="yellow"/>
                        <Color value="1" color="orange"/>
                        <Color value="0" color="black"/>
                    </ColorMap>
                </Field>
            </Plot>
        </Gnuplotter>
        <CellTracker format="ISBI 2012 (XML)" time-step="1"/>
        <Logger time-step="10">
            <Input>
                <Symbol symbol-ref="m.phi"/>
                <Symbol symbol-ref="A"/>
                <Symbol symbol-ref="B"/>
                <Symbol symbol-ref="s"/>
                <Symbol symbol-ref="H"/>
            </Input>
            <Output>
                <TextOutput/>
            </Output>
            <Plots>
                <Plot time-step="1">
                    <Style style="points"/>
                    <Terminal terminal="png"/>
                    <X-axis maximum="6.283">
                        <Symbol symbol-ref="m.phi"/>
                    </X-axis>
                    <Y-axis minimum="0.0">
                        <Symbol symbol-ref="A"/>
                        <Symbol symbol-ref="B"/>
                        <Symbol symbol-ref="s"/>
                        <Symbol symbol-ref="H"/>
                    </Y-axis>
                    <Range>
                        <Time mode="current"/>
                    </Range>
                </Plot>
            </Plots>
        </Logger>
        <ModelGraph format="dot" reduced="false" include-tags="#untagged"/>
        <Gnuplotter time-step="10" decorate="false" name="Collision detection plot">
            <Terminal name="png"/>
            <Plot title="Protrusion Field">
                <Cells value="cell.type">
                    <ColorMap>
                        <Color value="0" color="black"/>
                        <Color value="1" color="black"/>
                    </ColorMap>
                </Cells>
                <Field symbol-ref="U">
                    <ColorMap>
                        <Color value="0.0001" color="white"/>
                        <Color value="1" color="white"/>
                        <Color value="0" color="green"/>
                    </ColorMap>
                </Field>
            </Plot>
        </Gnuplotter>
        <Logger time-step="1.0">
            <Input>
                <Symbol symbol-ref="cell.center.x"/>
                <Symbol symbol-ref="cell.center.y"/>
                <Symbol symbol-ref="cell.surface"/>
                <Symbol symbol-ref="cell.volume"/>
                <Symbol symbol-ref="cell.length"/>
            </Input>
            <Output>
                <TextOutput file-name="cell_position"/>
            </Output>
        </Logger>
    </Analysis>
</MorpheusModel>
